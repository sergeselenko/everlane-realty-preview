{#- Article JSON-LD for guide/chapter pages (plan §2: named human author
    E-E-A-T — R2 §1.4). Dates flow from the KB pipeline (wave 2): the from-kb
    templates compute datePublished/dateModified from each entry's
    published/last_verified front matter. -#}
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "{{ title | safe }}",
  "description": "{{ description | safe }}",
  "url": "{{ site.url }}{{ page.url }}",
  "author": {
    "@type": "Person",
    "name": "{{ site.broker.name }}",
    "jobTitle": "{{ site.broker.title }}",
    "url": "{{ site.url }}/team/serge-osaulenko/"
  },
  "publisher": {
    "@type": "RealEstateAgent",
    "name": "Everlane Realty",
    "url": "{{ site.url }}/"
  }{% if datePublished %},
  "datePublished": "{{ datePublished }}",
  "dateModified": "{{ dateModified or datePublished }}"{% endif %}
}
