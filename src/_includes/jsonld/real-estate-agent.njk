{#- RealEstateAgent JSON-LD (plan §2 entity/schema layer, W1).
    Confirmed data from production. FILLED wave 1 (2026-07-08):
      · areaServed  = the decided positioning (working-notes: St. Pete identity
        + honest Pinellas/Tampa Bay; bio span Pink Streets → Clearwater).
      · sameAs      = the ORGANISATION's own profiles only (LinkedIn company,
        Facebook, Instagram) — entity sameAs should identify the entity. Serge's
        PERSON-scoped profiles (Zillow [operator-provided 2026-07-08], homes.com,
        YouTube, personal LinkedIn) live on the Person schema (person.njk), which
        is where Google reads the agent; the two are linked by worksFor. Google
        Business Profile OMITTED — none found on two web sweeps and the operator
        confirms he has none (a GBP is a high-value local-SEO add if/when he
        creates one: one line here). The FL DBPR license lives in
        employee.identifier (the machine-readable authoritative claim) rather
        than an unstable license-lookup URL.
    NO listing schema until the compliance lane clears it (R2 §1.2 caveat). -#}
{
  "@context": "https://schema.org",
  "@type": "RealEstateAgent",
  "name": "Everlane Realty",
  "url": "{{ site.url }}/",
  "telephone": "+1-727-490-8037",
  "email": "{{ site.broker.email }}",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "{{ site.broker.street }}",
    "addressLocality": "{{ site.broker.city }}",
    "addressRegion": "{{ site.broker.state }}",
    "postalCode": "{{ site.broker.zip }}",
    "addressCountry": "US"
  },
  "areaServed": [
    { "@type": "City", "name": "St. Petersburg, FL" },
    { "@type": "City", "name": "Clearwater, FL" },
    { "@type": "AdministrativeArea", "name": "Pinellas County, FL" },
    { "@type": "AdministrativeArea", "name": "Tampa Bay, FL" }
  ],
  "sameAs": [
    "https://www.linkedin.com/company/everlanerealty",
    "https://www.facebook.com/EverlaneRealty/",
    "https://www.instagram.com/everlanerealty/"
  ],
  "employee": {
    "@type": "Person",
    "name": "{{ site.broker.name }}",
    "jobTitle": "{{ site.broker.title }}",
    "identifier": "FL License #{{ site.broker.license }}"
  }
}
