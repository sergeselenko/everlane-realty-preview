{#- Breadcrumb component (plan §2: breadcrumbs throughout, hub-and-spoke).
    Consumes front matter `crumbs: [{title, url}, …]` (intermediate levels only;
    Home and the current page are added automatically). The matching
    BreadcrumbList JSON-LD is emitted in the head by layouts/base.njk. -#}
<nav class="breadcrumb" aria-label="Breadcrumb">
  <div class="wrap">
    <ol>
      <li><a href="/">Home</a></li>
      {%- for c in crumbs %}
      <li><a href="{{ c.url }}">{{ c.title }}</a></li>
      {%- endfor %}
      <li aria-current="page">{{ title }}</li>
    </ol>
  </div>
</nav>
